---
import { getCollection } from 'astro:content';

const jobs = await getCollection('career');
---

<div class="mx-auto max-w-4xl py-8">
    <h2 class="font-bold text-3xl mb-8">Career</h2>

    <div class="relative space-y-12">
        <div class="absolute left-2.5 top-2 bottom-2 w-0.5 -translate-x-1/2 bg-stone-200 dark:bg-stone-800"></div>

        {jobs.map((job) => (
            <div class="relative pl-10 group">
                <div class="absolute left-2.5 top-1.5 w-4 h-4 -translate-x-1/2 rounded-full border-4 border-white dark:border-stone-900 bg-primary shadow-sm z-10 transition-transform group-hover:scale-125"></div>
                
                <div class="flex flex-col md:flex-row md:gap-8">
                    <div class="md:w-32 shrink-0 mb-2 md:mb-0">
                        <span class="text-sm font-bold font-mono uppercase text-stone-500 dark:text-stone-500">
                            {job.data.start} - {job.data.end}
                        </span>
                    </div>

                    <div class="grow space-y-3">
                        <div>
                            <h3 class="text-xl font-bold text-stone-900 dark:text-stone-100 leading-none mb-1">
                                {job.data.role}
                            </h3>
                            <p class="text-stone-600 dark:text-stone-400 font-medium">
                                {job.data.company} • {job.data.location}
                            </p>
                        </div>
                        <p class="text-stone-600 dark:text-stone-400 max-w-2xl">
                            {job.data.description}
                        </p>
                    </div>
                </div>
            </div>
        ))}
    </div>
</div>
