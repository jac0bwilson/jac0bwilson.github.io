---
import { getCollection, render } from 'astro:content';

const jobs = await getCollection('career');
const sorted = jobs.sort(
    (left, right) => right.data.position - left.data.position,
);

const rendered = await Promise.all(
    sorted.map(async (entry) => ({ entry, ...(await render(entry)) })),
);
---

<div class="relative py-2">
    <h2 class="mb-4 text-3xl font-bold">Career</h2>

    <div class="relative">
        <div
            class="absolute top-0 bottom-0 left-2.5 w-0.5 -translate-x-1/2 bg-stone-200 dark:bg-stone-800"
        >
        </div>
        <div class="space-y-8">
            {
                rendered.map(({ entry, Content }) => (
                    <div class="group relative pl-10">
                        <div class="bg-accent absolute top-1.5 left-2.5 z-10 h-4 w-4 -translate-x-1/2 rounded-full border-4 border-white shadow-sm transition-transform group-hover:scale-125 dark:border-stone-800" />

                        <div class="flex flex-col md:flex-row md:gap-8">
                            <div class="mb-2 shrink-0 md:mb-0 md:w-32">
                                <span class="font-mono text-sm font-bold text-stone-500 uppercase dark:text-stone-500">
                                    {entry.data.start} - {entry.data.end}
                                </span>
                            </div>

                            <div class="grow space-y-3">
                                <div>
                                    <h3 class="mb-1 text-xl leading-none font-bold text-stone-900 dark:text-stone-100">
                                        {entry.data.role}
                                    </h3>
                                    <div class="font-medium text-stone-600 dark:text-stone-400">
                                        {entry.data.company} •{' '}
                                        {entry.data.location}
                                    </div>
                                </div>
                                <div class="text-stone-600 dark:text-stone-400">
                                    <Content />
                                </div>
                            </div>
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</div>
