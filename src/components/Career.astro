---
import { getCollection } from 'astro:content';

const jobs = await getCollection('career');
---

<div class="mx-auto max-w-4xl py-8">
    <h2 class="mb-8 text-3xl font-bold">Career</h2>

    <div class="relative space-y-12">
        <div
            class="absolute top-2 bottom-2 left-2.5 w-0.5 -translate-x-1/2 bg-stone-200 dark:bg-stone-800"
        >
        </div>

        {
            jobs.map((job) => (
                <div class="group relative pl-10">
                    <div class="bg-primary absolute top-1.5 left-2.5 z-10 h-4 w-4 -translate-x-1/2 rounded-full border-4 border-white shadow-sm transition-transform group-hover:scale-125 dark:border-stone-900" />

                    <div class="flex flex-col md:flex-row md:gap-8">
                        <div class="mb-2 shrink-0 md:mb-0 md:w-32">
                            <span class="font-mono text-sm font-bold text-stone-500 uppercase dark:text-stone-500">
                                {job.data.start} - {job.data.end}
                            </span>
                        </div>

                        <div class="grow space-y-3">
                            <div>
                                <h3 class="mb-1 text-xl leading-none font-bold text-stone-900 dark:text-stone-100">
                                    {job.data.role}
                                </h3>
                                <p class="font-medium text-stone-600 dark:text-stone-400">
                                    {job.data.company} • {job.data.location}
                                </p>
                            </div>
                            <p class="max-w-2xl text-stone-600 dark:text-stone-400">
                                {job.data.description}
                            </p>
                        </div>
                    </div>
                </div>
            ))
        }
    </div>
</div>
