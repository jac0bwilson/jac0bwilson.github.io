---
import { quietControlClass } from './controlStyles';
---

<button
    type="button"
    aria-label="Toggle theme"
    class:list={[
        quietControlClass,
        'text-foreground h-9 w-9 cursor-pointer justify-center text-lg',
    ]}
    data-theme-toggle
>
    <span aria-hidden="true" data-theme-icon>☀️</span>
</button>

<script is:inline>
    const root = document.documentElement;
    const button = document.querySelector('[data-theme-toggle]');
    const icon = document.querySelector('[data-theme-icon]');

    if (button instanceof HTMLButtonElement && icon instanceof HTMLElement) {
        const syncThemeIcon = () => {
            const isDark = root.classList.contains('dark');
            icon.textContent = isDark ? '🌙' : '☀️';
        };

        const setTheme = (theme) => {
            root.classList.toggle('dark', theme === 'dark');
            localStorage.setItem('theme', theme);
            syncThemeIcon();
        };

        syncThemeIcon();

        button.addEventListener('click', () => {
            const nextTheme = root.classList.contains('dark')
                ? 'light'
                : 'dark';
            setTheme(nextTheme);
        });

        const observer = new MutationObserver(syncThemeIcon);
        observer.observe(root, {
            attributes: true,
            attributeFilter: ['class'],
        });

        const mediaQuery = window.matchMedia('(prefers-color-scheme: dark)');
        mediaQuery.addEventListener('change', (event) => {
            if (!('theme' in localStorage)) {
                root.classList.toggle('dark', event.matches);
                syncThemeIcon();
            }
        });
    }
</script>
